{
  "name": "paper-digest-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "papers:daily": "node scripts/paper-agent.mjs --no-ai --no-email",
    "papers:email": "node scripts/paper-agent.mjs --email-only --send-email",
    "papers:demo": "node scripts/paper-agent.mjs --no-ai --no-email --max 5",
    "papers:help": "node scripts/paper-agent.mjs --help",
    "serve": "node scripts/serve.mjs",
    "dev": "node scripts/serve.mjs",
    "ai:test": "node scripts/test-ai.mjs",
    "papers:collect": "node scripts/paper-agent.mjs --mode all --no-ai --no-email",
    "papers:email-existing": "node scripts/paper-agent.mjs --email-only --send-email",
    "papers:collect:daily": "node scripts/paper-agent.mjs --mode daily --no-ai --no-email",
    "papers:collect:conference": "node scripts/paper-agent.mjs --mode conference --no-ai --no-email",
    "papers:collect:pdf": "node scripts/paper-agent.mjs --mode daily --no-ai --no-email --download-pdfs",
    "codex:digest": "node scripts/local-codex-digest.mjs",
    "codex:daily": "node scripts/local-codex-digest.mjs --pull --send-email --push",
    "codex:daily:sleep": "scripts/local-codex-daily-sleep.sh",
    "codex:dry-run": "node scripts/local-codex-digest.mjs --dry-run",
    "harness:prompt": "node scripts/build-codex-harness-prompt.mjs",
    "harness:validate": "node scripts/validate-digest-harness.mjs",
    "harness:validate:write": "node scripts/validate-digest-harness.mjs --write"
  },
  "engines": {
    "node": ">=18.17"
  }
}
